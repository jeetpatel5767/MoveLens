# MoveLens — required environment variables
# Copy this file to .env and fill in values before running.
# FORBIDDEN: ANTHROPIC_API_KEY, OPENAI_API_KEY, AUDIT_MODEL — never add these.

# === RENDER DEPLOYMENT — set these in the Render dashboard, not here ===
# SUI_GRAPHQL_URL, SUI_NETWORK, WALRUS_NETWORK, SUI_KEYPAIR_B64, GROQ_API_KEY,
# MEMWAL_ENABLED, DEMO_MODE_BLOB_ID, DEMO_PACKAGE_INFO_ID — all the same values
# as your local .env. LAYER4_SIDECAR_URL should be http://127.0.0.1:8765
# (the sidecar runs inside the SAME container, so localhost is correct here —
# do NOT use a Render public URL for this var).

SUI_GRAPHQL_URL=https://graphql.testnet.sui.io/graphql
SUI_NETWORK=testnet
WALRUS_NETWORK=testnet
SUI_KEYPAIR_B64=                 # funded testnet keypair for Walrus/MVR txs (base64)
LAYER4_SIDECAR_URL=http://127.0.0.1:8765
GROQ_API_KEY=your_key_here       # REQUIRED for real Layer 4 classification (free at console.groq.com).
                                 # Without it, Layer 4 runs in keyword-heuristic-only fallback mode.
OPENROUTER_API_KEY=              # unused — reserved for future alternative
MEMWAL_ENABLED=true
DEMO_MODE_BLOB_ID=5cN1fBWk5TIXUlJv-Do7pWYjc3AknRCJ-buNt_JdnPA  # Cetus audit — used as fallback when Walrus upload fails during demo
